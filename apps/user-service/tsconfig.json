{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS", 
    "outDir": "./dist",   
    "rootDir": "./",
    "lib": ["ESNext"],    
    "noEmit": false,
    "baseUrl": ".",
    "paths": {
      "@modules/*": ["src/modules/*"],
      "@shared/*": ["src/shared/*"],
      "@config/*": ["src/config/*"]
    }
  },
  "include": ["src/**/*", "tests/**/*"],
  "exclude": ["node_modules", "dist"],
}