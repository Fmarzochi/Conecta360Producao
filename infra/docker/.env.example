# =============================================================================
# MONGODB - CREDENCIAIS ROOT (apenas para o container local)
# =============================================================================
MONGO_ROOT_USER=root
MONGO_ROOT_PASSWORD=root_password_local

# =============================================================================
# MONGODB - BANCO DA APLICAÇÃO
# =============================================================================
MONGO_DB_NAME=conecta360
MONGO_APP_USER=conecta360_user
MONGO_APP_PASSWORD=app_password_local
MONGO_PORT=27017

# =============================================================================
# MONGO EXPRESS - INTERFACE GRÁFICA (http://localhost:8081)
# =============================================================================
MONGO_EXPRESS_USER=admin
MONGO_EXPRESS_PASSWORD=admin123
MONGO_EXPRESS_PORT=8081

# =============================================================================
# CONNECTION STRING (para usar nas aplicações fora do Docker)
# Copie o valor abaixo para o .env do serviço correspondente
# =============================================================================
MONGO_CONNECTION_STRING=mongodb://conecta360_user:app_password_local@localhost:27017/conecta360

# =============================================================================
# PRISMA - DATABASE URL
# Usado pelo Prisma ORM para conectar ao banco (fora do Docker)
# Dentro do Docker o serviço prisma-migrate usa o hostname 'mongodb' automaticamente
# =============================================================================
DATABASE_URL=mongodb://conecta360_user:app_password_local@localhost:27017/conecta360?authSource=conecta360
